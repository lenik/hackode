#, c-format
msgid "%s: copying from %s"
msgstr "%s: %s kara kopii chu"

#: src/hackode/lib.c:67
#, c-format
msgid "%s: %s: %s"
msgstr "%s: %s: %s"

#: src/hackode/lib.c:76
#, c-format
msgid "%s: write error"
msgstr "%s: 書き込みエラー"

#: src/hackode/dict_tool.c:19
#, c-format
msgid "Usage: %s <text_dict> <dict.map>"
msgstr "tsukaikata: %s <text_dict> <dict.map>"

#: src/hackode/dict_tool.c:25
#, c-format
msgid "%s: failed to compile %s -> %s (err=%d)"
msgstr "%s: %s -> %s no konpairu ni shippai shimashita (err=%d)"
